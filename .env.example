# AgencyReport AI production environment template

PORT=4280
NODE_ENV=production

# Database
DATABASE_URL=postgres://user:password@host:5432/agencyreport
DATABASE_SSL=true

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_PROVIDER=openai-compatible
# AI_API_KEY=
# AI_BASE_URL=https://provider.example/v1

# Email delivery
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=AgencyReport AI <reports@your-domain.example>
# Optional generic API mode
# EMAIL_PROVIDER=api
# EMAIL_API_URL=https://email-provider.example/send
# EMAIL_API_KEY=
# Optional local test recipient for npm run email:check
# EMAIL_TEST_TO=you@example.com

# Worker / cron
WORKER_SECRET=replace-with-long-random-secret

# Basic API abuse protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20

# Public app URL, used to build payment callback URLs.
APP_BASE_URL=https://app.virtualtrendworks.com

# Payment provider: ecpay, stripe, or mock.
PAYMENT_PROVIDER=ecpay
ECPAY_MODE=production
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_RETURN_URL=https://app.virtualtrendworks.com/api/billing/ecpay/return
ECPAY_ORDER_RESULT_URL=https://app.virtualtrendworks.com/billing/ecpay/result
ECPAY_CLIENT_BACK_URL=https://app.virtualtrendworks.com

# Optional Stripe alternative
# PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=https://your-domain.example/billing/success
STRIPE_CANCEL_URL=https://your-domain.example/billing/cancel
STRIPE_WEBHOOK_SECRET=

# Data connectors
CONNECTOR_ENCRYPTION_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_SHEETS_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v23.0
GA4_PROPERTY_ID=

# Monitoring and backup readiness
SENTRY_DSN=
MONITORING_URL=
BACKUP_ENABLED=true
BACKUP_POLICY_URL=
BACKUP_ENCRYPTION_KEY=
# Legal publication gate. Set true only after the published version is reviewed.
LEGAL_VERSION=legal-2026-06-18
LEGAL_REVIEWED=false
