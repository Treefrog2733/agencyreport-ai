# AgencyReport AI production environment template

PORT=4280
NODE_ENV=production

# Database
DATABASE_URL=postgres://user:password@host:5432/agencyreport
DATABASE_SSL=true

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_PROVIDER=openai-compatible
# AI_API_KEY=
# AI_BASE_URL=https://provider.example/v1

# Email delivery
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=AgencyReport AI <reports@your-domain.example>
# Optional generic API mode
# EMAIL_PROVIDER=api
# EMAIL_API_URL=https://email-provider.example/send
# EMAIL_API_KEY=
# Optional local test recipient for npm run email:check
# EMAIL_TEST_TO=you@example.com

# Worker / cron
WORKER_SECRET=replace-with-long-random-secret

# Payment provider
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=https://your-domain.example/billing/success
STRIPE_CANCEL_URL=https://your-domain.example/billing/cancel
STRIPE_WEBHOOK_SECRET=

# Data connectors
GOOGLE_SHEETS_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_ACCESS_TOKEN=
META_APP_ID=
GA4_PROPERTY_ID=

# Monitoring and backup readiness
SENTRY_DSN=
MONITORING_URL=
BACKUP_ENABLED=true
BACKUP_POLICY_URL=
